-- Loop de Renderização
RunService.RenderStepped:Connect(function()
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    for obj, data in pairs(ESPCache) do
        if not obj or not obj.Parent or not KnownItems[obj] then
            removeESP(obj)
            continue
        end
        if data.type == "ak47 rgb" and isHeldByPlayer(obj) then
            removeESP(obj)
            continue
        end
        local root = data.root
        if not root or not root.Parent then
            removeESP(obj)
            continue
        end
        
        if data.type == "ak47 rgb" then
            local hue = (tick() * 0.5) % 1
            local rgbColor = Color3.fromHSV(hue, 1, 1)
            data.line.Color = rgbColor
            data.label.TextColor3 = rgbColor
            if data.highlight then
                data.highlight.FillColor = rgbColor
            end
        end
        
        local pos, onScreen = camera:WorldToViewportPoint(root.Position)
        if hrp then
            local dist = math.floor((hrp.Position - root.Position).Magnitude)
            data.label.Text = data.name .. "\n["..dist.."m]"
        end
        if onScreen and Settings.Tracers then
            data.line.From = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y)
            data.line.To = Vector2.new(pos.X, pos.Y)
            data.line.Visible = true
        else
            data.line.Visible = false
        end
    end
end)

-- Funções de Scan
local function scanObject(obj)
    local typ = checkMatch(obj)
    if typ then
        if typ == "ak47 rgb" and isHeldByPlayer(obj) then
            return
        end
        KnownItems[obj] = typ
        local isActive = false
        if typ == "almond water" then isActive = Settings.AlmondWater
        elseif typ == "energy drink" then isActive = Settings.EnergyDrink
        elseif typ == "lantern" then isActive = Settings.Lantern
        elseif typ == "radar" then isActive = Settings.Radar
        elseif typ == "radar player" then isActive = Settings.RadarPlayer
        elseif typ == "berretta" then isActive = Settings.Berretta
        elseif typ == "357" then isActive = Settings.Revolver357
        elseif typ == "glock 18" then isActive = Settings.Glock18
        elseif typ == "ak47 rgb" then isActive = Settings.Ak47
        end
        if isActive then
            createESP(obj, typ)
        end
    end
end

for _, obj in ipairs(workspace:GetDescendants()) do
    scanObject(obj)
end

workspace.DescendantAdded:Connect(function(obj)
    task.delay(0.5, function()
        if obj and obj.Parent then
            scanObject(obj)
        end
    end)
end)

workspace.DescendantRemoving:Connect(function(obj)
    if KnownItems[obj] then
        KnownItems[obj] = nil
        removeESP(obj)
    end
end)
