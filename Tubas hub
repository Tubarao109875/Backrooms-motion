local PlayerTab = Window:CreateTab("Player")

-- Variáveis para controlar os loops de velocidade
local speedLoopConnection = nil
local staminaToggle, infSpeedToggle, energySpeedToggle -- Variáveis para os objetos de toggle

-- Função para parar qualquer loop de velocidade e resetar para o padrão
local function stopSpeedLoop()
    if speedLoopConnection then
        speedLoopConnection:Disconnect()
        speedLoopConnection = nil
    end
    local character = player.Character
    if character then
        local humanoid = character:FindFirstChildWhichIsA("Humanoid")
        if humanoid and humanoid.WalkSpeed ~= 10 then
            humanoid.WalkSpeed = 10
        end
    end
end

-- Função para iniciar o loop com uma velocidade específica
local function startSpeedLoop(speed)
    stopSpeedLoop() -- Garante que nenhum outro loop esteja rodando
    speedLoopConnection = RunService.RenderStepped:Connect(function()
        local character = player.Character
        if character then
            local humanoid = character:FindFirstChildWhichIsA("Humanoid")
            if humanoid and humanoid.WalkSpeed ~= speed then
                humanoid.WalkSpeed = speed
            end
        end
    end)
end

