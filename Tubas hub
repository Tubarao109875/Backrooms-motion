local function isHeldByPlayer(item)
    local parent = item.Parent
    if parent and parent:FindFirstChildWhichIsA("Humanoid") and game.Players:GetPlayerFromCharacter(parent) then
        return true
    end
    if parent and parent.Parent and parent.Parent:FindFirstChildWhichIsA("Humanoid") and game.Players:GetPlayerFromCharacter(parent.Parent) then
        return true
    end
    return false
end

local function checkMatch(obj)
    local str = string.lower(obj.Name)
    if string.find(str, "almond water") or string.find(str, "almond") then return "almond water" end
    if string.find(str, "energy drink") or string.find(str, "energy") then return "energy drink" end
    if string.find(str, "lantern") or string.find(str, "lanter") then return "lantern" end
    if string.find(str, "radar player") then return "radar player" end
    if string.find(str, "radar") then return "radar" end
    if string.find(str, "berretta") or string.find(str, "m9") then return "berretta" end
    if string.find(str, "357") or string.find(str, "revolver") then return "357" end
    if string.find(str, "glock") or string.find(str, "g18") or string.find(str, "pistol") then return "glock 18" end
    if string.find(str, "ak47") or string.find(str, "ak-47") then return "ak47 rgb" end
    return nil
end

local function getBeautifulName(typ)
    local names = {
        ["almond water"] = "Almond Water",
        ["energy drink"] = "Energy Drink",
        ["lantern"] = "Lantern",
        ["radar"] = "Radar",
        ["radar player"] = "Radar Player",
        ["berretta"] = "Berretta",
        ["357"] = ".357 Revolver",
        ["glock 18"] = "Glock 18",
        ["ak47 rgb"] = "AK-47 RGB"
    }
    return names[typ] or "Unknown"
end

local function getRoot(obj)
    if obj:IsA("BasePart") then
        return obj
    end
    if obj:IsA("Model") then
        return obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart", true)
    end
    return nil
end

local function createESP(obj, typ)
    if ESPCache[obj] then return end
    local root = getRoot(obj)
    if not root then return end
    local color = Colors[typ] or Color3.new(1,1,1)
    local gui = Instance.new("BillboardGui")
    gui.Name = "ESP"
    gui.Size = UDim2.new(0, 160, 0, 50)
    gui.AlwaysOnTop = true
    gui.StudsOffset = Vector3.new(0, 2.5, 0)
    gui.Parent = root
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1,0,1,0)
    label.BackgroundTransparency = 1
    label.TextColor3 = color
    label.Font = Enum.Font.GothamBold
    label.TextSize = 14
    label.Parent = gui
    Instance.new("UIStroke", label).Thickness = 1.5
    local highlight = Instance.new("Highlight")
    highlight.Parent = obj
    highlight.FillColor = color
    highlight.OutlineColor = Color3.new(1,1,1)
    highlight.FillTransparency = 0.4
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Enabled = Settings.Highlights
    local line = Drawing.new("Line")
    line.Visible = false
    line.Thickness = 1.5
    line.Transparency = 0.8
    line.Color = color
    ESPCache[obj] = {
        gui = gui,
        label = label,
        root = root,
        line = line,
        highlight = highlight,
        name = getBeautifulName(typ),
        type = typ
    }
end

local function removeESP(obj)
    if ESPCache[obj] then
        local e = ESPCache[obj]
        if e.gui then e.gui:Destroy() end
        if e.highlight then e.highlight:Destroy() end
        if e.line then
            e.line.Visible = false
            e.line:Remove()
        end
        ESPCache[obj] = nil
    end
end

local function updateESPType(typ, isEnabled)
    for obj, objType in pairs(KnownItems) do
        if objType == typ then
            if isEnabled then
                if typ == "ak47 rgb" and isHeldByPlayer(obj) then
                else
                    createESP(obj, typ)
                end
            else
                removeESP(obj)
            end
        end
    end
end

